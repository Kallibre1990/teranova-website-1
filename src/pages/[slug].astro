---
/* Real content pages (default locale, ru). One dynamic route renders the right page
   component per slug. ru/en/ko are indexed; machine locales are noindex via Base. */
import Base from '../layouts/Base.astro';
import Catalog from '../components/pages/Catalog.astro';
import Buyers from '../components/pages/Buyers.astro';
import VerifyPage from '../components/pages/VerifyPage.astro';
import About from '../components/pages/About.astro';
import Suppliers from '../components/pages/Suppliers.astro';
import Team from '../components/pages/Team.astro';
import Tenders from '../components/pages/Tenders.astro';
import Faq from '../components/pages/Faq.astro';
import Contacts from '../components/pages/Contacts.astro';
import { ui } from '../i18n/ui';
import { faqJsonLd } from '../data/jsonld';

type Slug = 'catalog' | 'buyers' | 'how-we-verify' | 'about' | 'suppliers' | 'team' | 'tenders' | 'faq' | 'contacts';
const COMP: Record<Slug, any> = { catalog: Catalog, buyers: Buyers, 'how-we-verify': VerifyPage, about: About, suppliers: Suppliers, team: Team, tenders: Tenders, faq: Faq, contacts: Contacts };
const PKEY: Record<Slug, 'catalog' | 'buyers' | 'verify' | 'about' | 'suppliers' | 'team' | 'tenders' | 'faq' | 'contacts'> = { catalog: 'catalog', buyers: 'buyers', 'how-we-verify': 'verify', about: 'about', suppliers: 'suppliers', team: 'team', tenders: 'tenders', faq: 'faq', contacts: 'contacts' };

export function getStaticPaths() {
  return (['catalog', 'buyers', 'how-we-verify', 'about', 'suppliers', 'team', 'tenders', 'faq', 'contacts'] as Slug[]).map((slug) => ({ params: { slug }, props: { slug } }));
}

const { slug } = Astro.props as { slug: Slug };
const lang = 'ru' as const;
const t = ui[lang];
const meta = t.pages[PKEY[slug]];
const Comp = COMP[slug];
const jsonLd = slug === 'faq' ? faqJsonLd(lang) : undefined;
---

<Base lang={lang} path={`/${slug}`} title={`${meta.title} — Teranova Group`} description={meta.sub} jsonLd={jsonLd}>
  <Comp lang={lang} />
</Base>
