---
import Base from '../layouts/Base.astro';
import CenteredNotice from '../components/CenteredNotice.astro';
import { ui } from '../i18n/ui';
import { localizePath } from '../i18n/utils';

const lang = 'ru' as const;
const t = ui[lang];
---

<Base lang={lang} path="/thanks" title={`${t.thanks.title} — Teranova Group`} description={t.thanks.body} noindex>
  <CenteredNotice icon="check" title={t.thanks.title} body={t.thanks.body} backHref={localizePath('/', lang)} backLabel={t.thanks.back} />
</Base>
