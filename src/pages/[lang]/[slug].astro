---
/* Real content pages for the non-default locales (en, ko indexed; machine locales noindex). */
import Base from '../../layouts/Base.astro';
import Catalog from '../../components/pages/Catalog.astro';
import Buyers from '../../components/pages/Buyers.astro';
import VerifyPage from '../../components/pages/VerifyPage.astro';
import About from '../../components/pages/About.astro';
import Suppliers from '../../components/pages/Suppliers.astro';
import Faq from '../../components/pages/Faq.astro';
import Contacts from '../../components/pages/Contacts.astro';
import { ui, defaultLang, languages, type Lang } from '../../i18n/ui';

type Slug = 'catalog' | 'buyers' | 'how-we-verify' | 'about' | 'suppliers' | 'faq' | 'contacts';
const COMP: Record<Slug, any> = { catalog: Catalog, buyers: Buyers, 'how-we-verify': VerifyPage, about: About, suppliers: Suppliers, faq: Faq, contacts: Contacts };
const PKEY: Record<Slug, 'catalog' | 'buyers' | 'verify' | 'about' | 'suppliers' | 'faq' | 'contacts'> = { catalog: 'catalog', buyers: 'buyers', 'how-we-verify': 'verify', about: 'about', suppliers: 'suppliers', faq: 'faq', contacts: 'contacts' };

export function getStaticPaths() {
  const slugs: Slug[] = ['catalog', 'buyers', 'how-we-verify', 'about', 'suppliers', 'faq', 'contacts'];
  return (Object.keys(languages) as Lang[])
    .filter((l) => l !== defaultLang)
    .flatMap((lang) => slugs.map((slug) => ({ params: { lang, slug }, props: { lang, slug } })));
}

const { lang, slug } = Astro.props as { lang: Lang; slug: Slug };
const t = ui[lang];
const meta = t.pages[PKEY[slug]];
const Comp = COMP[slug];
---

<Base lang={lang} path={`/${slug}`} title={`${meta.title} — Teranova Group`} description={meta.sub}>
  <Comp lang={lang} />
</Base>
