---
import Base from '../../layouts/Base.astro';
import Home from '../../components/home/Home.astro';
import { ui, defaultLang, languages, type Lang } from '../../i18n/ui';
import { homeJsonLd } from '../../data/jsonld';

export function getStaticPaths() {
  return (Object.keys(languages) as Lang[])
    .filter((l) => l !== defaultLang)
    .map((lang) => ({ params: { lang }, props: { lang } }));
}

const { lang } = Astro.props as { lang: Lang };
const t = ui[lang];
---

<Base lang={lang} path="/" title={t.meta.home_title} description={t.meta.home_desc} jsonLd={homeJsonLd(lang)}>
  <Home lang={lang} />
</Base>
