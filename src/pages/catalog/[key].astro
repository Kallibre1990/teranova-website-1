---
/* Catalog group page (default locale, ru) — one per category key. */
import Base from '../../layouts/Base.astro';
import CatalogGroup from '../../components/pages/CatalogGroup.astro';
import { ui } from '../../i18n/ui';
import { categoryKeys, type CategoryKey } from '../../data/site';
import { breadcrumbJsonLd } from '../../data/jsonld';

export function getStaticPaths() {
  return categoryKeys.map((key) => ({ params: { key }, props: { key } }));
}

const { key } = Astro.props as { key: CategoryKey };
const lang = 'ru' as const;
const t = ui[lang];
const group = t.categories.groups.find((g) => g.key === key)!;
// Cosmetics has bespoke, keyword-first SEO meta; other categories use the default.
const cos = key === 'cosmetics' ? t.pages.cosmetics : null;
const metaTitle = cos ? cos.seo_title : `${group.name} — Teranova Group`;
const metaDesc = cos ? cos.seo_desc : `${group.blurb} · ${group.items.join(', ')}`;
---

<Base lang={lang} path={`/catalog/${key}`} title={metaTitle} description={metaDesc} jsonLd={breadcrumbJsonLd(lang, group)}>
  <CatalogGroup lang={lang} groupKey={key} />
</Base>
