---
import '@fontsource-variable/manrope';
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Preloader from '../components/Preloader.astro';
import { ui, isVerified, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  path: string;
  title: string;
  description: string;
  jsonLd?: object | object[];
  noindex?: boolean;
}
const { lang, path, title, description, jsonLd, noindex } = Astro.props;
const t = ui[lang];
// Pages are index/follow by default (every locale is indexed); only pages that
// explicitly pass noindex (e.g. /thanks, /404) are excluded.
const noindexResolved = noindex ?? !isVerified(lang);
---

<!doctype html>
<html lang={t.htmlLang}>
  <head>
    <BaseHead lang={lang} path={path} title={title} description={description} jsonLd={jsonLd} noindex={noindexResolved} />
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">{t.common.skip}</a>
    <Preloader />
    <Header lang={lang} path={path} />
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <Footer lang={lang} />
    <button class="to-top" id="toTop" aria-label={t.common.to_top}>↑</button>

    <div class="cursor" id="cursor" aria-hidden="true">
      <span class="cursor__ring"></span><span class="cursor__dot"></span>
    </div>

    <script>
      import '../scripts/motion';
    </script>

    <style>
      .to-top {
        position: fixed; right: 22px; bottom: 22px;
        width: 44px; height: 44px; border-radius: 50%; border: none;
        background: var(--cobalt); color: #fff; font-size: 1.15rem;
        display: flex; align-items: center; justify-content: center;
        box-shadow: var(--sh-m); z-index: 80;
        opacity: 0; transform: translateY(12px); pointer-events: none;
        transition: opacity .3s var(--ease), transform .3s var(--ease), background .2s;
      }
      .to-top.show { opacity: 1; transform: none; pointer-events: auto; }
      .to-top:hover { background: var(--cobalt-light); }
    </style>
  </body>
</html>
