---
/* Light preloader: brand diamond reveal, fades out on load. Only shown when JS is
   on (html.js) so crawlers / no-JS users see content immediately. */
---

<div class="preloader" id="preloader" aria-hidden="true">
  <span class="preloader__mark">
    <img src="/brand/teranova-icon-light.svg" alt="" width="80" height="80" />
  </span>
</div>

<style is:global>
  .preloader { display: none; }
  html.js .preloader {
    display: grid; place-items: center;
    position: fixed; inset: 0; z-index: 9999; background: var(--navy-deep);
    transition: opacity .6s ease, visibility .6s ease;
  }
  .preloader__mark { width: 76px; height: 76px; animation: pl-in .9s var(--ease) both; }
  .preloader__mark img { width: 100%; height: 100%; filter: drop-shadow(0 10px 30px rgba(37, 99, 212, 0.5)); }
  .preloader.is-done { opacity: 0; visibility: hidden; pointer-events: none; }
  @keyframes pl-in { 0% { opacity: 0; transform: translateY(8px) scale(.92); } 100% { opacity: 1; transform: none; } }
  @media (prefers-reduced-motion: reduce) {
    html.js .preloader { transition: none; }
    .preloader__mark { animation: none; }
  }
</style>

<script is:inline>
  (function () {
    var el = document.getElementById('preloader');
    if (!el) return;
    var hide = function () { el.classList.add('is-done'); };
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) { hide(); return; }
    var done = false;
    var run = function () { if (done) return; done = true; setTimeout(hide, 250); };
    window.addEventListener('load', run);
    setTimeout(run, 1600); // failsafe
  })();
</script>
