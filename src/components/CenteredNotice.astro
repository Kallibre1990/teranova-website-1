---
interface Props {
  icon?: 'check' | 'soon';
  title: string;
  body: string;
  backHref: string;
  backLabel: string;
}
const { icon = 'check', title, body, backHref, backLabel } = Astro.props;
---

<section class="notice">
  <div class="notice__glow" aria-hidden="true"></div>
  <div class="wrap notice__inner">
    <span class="notice__icon" aria-hidden="true">
      {
        icon === 'check' ? (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="m8 12 2.5 2.5L16 9"/></svg>
        ) : (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
        )
      }
    </span>
    <h1 class="notice__title metal">{title}</h1>
    <p class="notice__body">{body}</p>
    <a class="btn btn--primary btn--lg" href={backHref}>{backLabel}</a>
  </div>
</section>

<style>
  .notice {
    position: relative; overflow: hidden;
    background: radial-gradient(120% 120% at 50% -20%, #102a52 0%, var(--navy) 50%, var(--navy-deep) 100%);
    color: #fff; min-height: calc(100vh - var(--nav-h));
    display: flex; align-items: center; text-align: center;
    padding: 80px 0;
  }
  .notice__glow { position: absolute; top: -160px; left: 50%; transform: translateX(-50%); width: 620px; height: 620px; background: radial-gradient(circle, rgba(37, 99, 212, 0.3) 0%, transparent 68%); pointer-events: none; }
  .notice__inner { position: relative; z-index: 1; max-width: 560px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; }
  .notice__icon { width: 64px; height: 64px; border-radius: 18px; display: flex; align-items: center; justify-content: center; background: rgba(37, 99, 212, 0.16); border: 1px solid rgba(63, 122, 224, 0.4); color: var(--cobalt-light); margin-bottom: 26px; }
  .notice__icon svg { width: 32px; height: 32px; }
  .notice__title { font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 800; letter-spacing: -0.02em; margin-bottom: 16px; }
  .notice__body { font-size: 1.05rem; color: var(--silver); line-height: 1.7; margin-bottom: 32px; }
</style>
