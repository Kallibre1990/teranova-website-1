---
import { localizePath, getAlternates } from '../i18n/utils';
import { defaultLang, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  /** Logical (default-locale) path, e.g. '/' or '/catalog'. */
  path: string;
  title: string;
  description: string;
  image?: string;
  jsonLd?: object | object[];
  noindex?: boolean;
}
const { lang, path, title, description, image = '/brand/og-default.png', jsonLd, noindex = false } = Astro.props;

const siteUrl = (Astro.site?.toString() ?? 'https://teranovagroup.com/').replace(/\/$/, '');
const canonical = siteUrl + localizePath(path, lang);
const alternates = getAlternates(path).map((a) => ({ ...a, abs: siteUrl + a.href }));
const xDefault = siteUrl + localizePath(path, defaultLang);
const ogImage = image.startsWith('http') ? image : siteUrl + image;
const ogLocale: Record<Lang, string> = {
  ru: 'ru_RU', en: 'en_US', ko: 'ko_KR', zh: 'zh_CN', ja: 'ja_JP', it: 'it_IT', de: 'de_DE', fr: 'fr_FR', tr: 'tr_TR', es: 'es_ES',
};
const jsonLdList = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<title>{title}</title>
<meta name="description" content={description} />
{noindex && <meta name="robots" content="noindex, follow" />}
<link rel="canonical" href={canonical} />

{alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.abs} />)}
<link rel="alternate" hreflang="x-default" href={xDefault} />

<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<meta name="theme-color" content="#0b1b35" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Teranova Group" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:locale" content={ogLocale[lang]} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- Fonts: Manrope is self-hosted (woff2) via @fontsource-variable/manrope, imported
     in Base.astro — no Google Fonts CDN. Korean falls back to system Hangul fonts. -->

{jsonLdList.map((data) => <script is:inline type="application/ld+json" set:html={JSON.stringify(data).replace(/</g, '\\u003c')} />)}
