---
import PageHead from './PageHead.astro';
import Atmosphere from '../visual/Atmosphere.astro';
import { anchorHref } from '../../i18n/utils';
import { ui, type Lang } from '../../i18n/ui';
interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
const p = t.pages.team;
---

<PageHead sup={t.nav.team} title={p.title} sub={p.sub} />

<section class="section section--navy">
  <Atmosphere variant="dark" />
  <div class="wrap">
    <div class="team-grid">
      {
        p.members.map((m) => (
          <figure class="tcard">
            <div class="tcard__photo">
              <img src={m.photo} alt={`${m.name} — ${m.role}`} width="800" height="1000" loading="lazy" decoding="async" />
            </div>
            <figcaption class="tcard__body">
              <span class="tcard__name">{m.name}</span>
              <span class="tcard__role">{m.role}</span>
              <p class="tcard__bio">{m.bio}</p>
            </figcaption>
          </figure>
        ))
      }
    </div>
    <p class="page-note">{p.note}</p>
    <div class="page-cta">
      <a class="btn btn--primary btn--lg" href={anchorHref('ondemand', lang)}>{p.cta}</a>
    </div>
  </div>
</section>

<style>
  .team-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; }
  .tcard {
    display: flex; flex-direction: column; overflow: hidden;
    background: rgba(255, 255, 255, 0.035); border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--r-lg);
  }
  .tcard__photo { aspect-ratio: 4 / 5; background: var(--navy-2); }
  .tcard__photo img { width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block; }
  .tcard__body { padding: 18px 18px 22px; display: flex; flex-direction: column; }
  .tcard__name { font-size: 1.06rem; font-weight: 800; color: #fff; letter-spacing: -0.01em; }
  .tcard__role { font-size: 0.82rem; font-weight: 700; color: var(--cobalt-light); letter-spacing: 0.02em; margin-top: 4px; }
  .tcard__bio { font-size: 0.9rem; color: var(--silver); line-height: 1.6; margin-top: 12px; }

  @media (max-width: 920px) { .team-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 460px) { .team-grid { grid-template-columns: 1fr; } }
</style>
