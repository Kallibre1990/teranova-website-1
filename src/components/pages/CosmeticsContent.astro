---
/* Cosmetics category — approved editorial content (blocks 1–7). Rendered only on
   /catalog/cosmetics/ by CatalogGroup. `part="body"` = blocks 1–6 above the demo
   grids (block 1's title/text live in the page head); `part="cta"` = block 7, the
   closing CTA below the grids. Styled with existing dark-section tokens — global
   design unchanged. */
import { anchorHref } from '../../i18n/utils';
import { ui, type Lang } from '../../i18n/ui';
interface Props {
  lang: Lang;
  part?: 'body' | 'cta';
}
const { lang, part = 'body' } = Astro.props;
const c = ui[lang].pages.cosmetics;
const ondemand = anchorHref('ondemand', lang);
---

{
  part === 'cta' && (
    <section class="section section--navy cos cos--cta">
      <div class="wrap">
        <div class="cos-ctaband">
          <h2 class="cos-ctaband__t">{c.cta_title}</h2>
          <p class="cos-ctaband__d">{c.cta_body}</p>
          <div class="cos-btns">
            <a class="btn btn--primary" href={ondemand}>{c.cta_primary}</a>
            <a class="btn btn--ghost" href={ondemand}>{c.cta_secondary}</a>
          </div>
        </div>
      </div>
    </section>
  )
}

{
  part === 'body' && (
    <section class="section section--navy cos">
      <div class="wrap">
        <div class="cos-btns cos-btns--top">
          <a class="btn btn--primary" href={ondemand}>{c.cta_primary}</a>
          <a class="btn btn--ghost" href={ondemand}>{c.cta_secondary}</a>
        </div>

        <div class="cos-block">
          <h2 class="cos-h">{c.hard_title}</h2>
          <div class="cos-cards">
            {c.hard_points.map((p) => (
              <article class="cos-card">
                <h3 class="cos-card__t">{p.t}</h3>
                <p class="cos-card__d">{p.d}</p>
              </article>
            ))}
          </div>
        </div>

        <div class="cos-block">
          <h2 class="cos-h">{c.models_title}</h2>
          <p class="cos-sub">{c.models_sub}</p>
          <div class="cos-models">
            {c.models.map((m) => (
              <article class="cos-model">
                <span class="cos-model__name">{m.name}</span>
                <p class="cos-model__desc">{m.desc}</p>
              </article>
            ))}
          </div>
        </div>

        <div class="cos-block cos-two">
          <div>
            <h3 class="cos-lvl">{c.process_title}</h3>
            <ol class="cos-order">{c.process.map((p) => <li>{p}</li>)}</ol>
          </div>
          <div class="cos-facts">
            {c.facts.map((f) => (
              <div class="cos-fact">
                <span class="cos-fact__k">{f.k}</span>
                <p class="cos-fact__v">{f.v}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="cos-block cos-markets">
          <h2 class="cos-h">{c.markets_title}</h2>
          <p class="cos-markets__body">{c.markets_body}</p>
          <ul class="cos-reglist">
            {c.markets_list.map((m) => (
              <li>
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M21 10c0 6-9 12-9 12s-9-6-9-12a9 9 0 0 1 18 0Z" />
                  <circle cx="12" cy="10" r="3" />
                </svg>
                <span>{m}</span>
              </li>
            ))}
          </ul>
          <p class="cos-note">{c.markets_note}</p>
        </div>

        <div class="cos-block">
          <h2 class="cos-h">{c.eco_title}</h2>
          <div class="cos-eco">
            {c.eco_items.map((e) => (
              <article class="cos-eco__item">
                <h3 class="cos-eco__t">{e.t}</h3>
                <p class="cos-eco__d">{e.d}</p>
              </article>
            ))}
          </div>
          <p class="cos-note">{c.eco_note}</p>
        </div>

        <div class="cos-block">
          <h2 class="cos-h">{c.why_title}</h2>
          <ul class="cos-scope">
            {c.why_points.map((p) => (
              <li>
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 12 5 5L20 7" /></svg>
                <span>{p}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  )
}

<style>
  .cos { padding-top: clamp(28px, 4vw, 44px); }
  .cos--cta { padding-top: 0; }
  .cos-block { margin-bottom: clamp(38px, 6vw, 64px); }
  .cos-h { font-size: clamp(1.35rem, 2.4vw, 1.85rem); font-weight: 800; letter-spacing: -0.01em; color: #fff; max-width: 30ch; }
  .cos-sub { font-size: 1rem; color: var(--silver); margin-top: 10px; }
  .cos-lvl { font-size: 0.74rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--silver-muted); margin-bottom: 12px; }
  .cos-note { font-size: 0.9rem; color: var(--silver-muted); line-height: 1.6; margin-top: 16px; max-width: 74ch; }

  .cos-btns { display: flex; flex-wrap: wrap; gap: 12px; }
  .cos-btns--top { margin-bottom: clamp(38px, 6vw, 60px); }

  /* Block 2 — why hard alone */
  .cos-cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 22px; }
  .cos-card { background: rgba(255, 255, 255, 0.035); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: var(--r-lg); padding: 20px; }
  .cos-card__t { font-size: 1rem; font-weight: 800; color: var(--cobalt-light); }
  .cos-card__d { font-size: 0.88rem; color: var(--silver); line-height: 1.6; margin-top: 8px; }

  /* Block 3 — three models */
  .cos-models { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 22px; }
  .cos-model { display: flex; flex-direction: column; background: rgba(255, 255, 255, 0.035); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: var(--r-lg); padding: 22px; }
  .cos-model__name { font-size: 1.1rem; font-weight: 800; color: var(--cobalt-light); }
  .cos-model__desc { font-size: 0.9rem; color: var(--silver); line-height: 1.6; margin-top: 12px; }

  /* process + facts */
  .cos-two { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(24px, 4vw, 48px); align-items: start; }
  .cos-order { margin: 0; padding: 0; list-style: none; counter-reset: cos; }
  .cos-order li { position: relative; counter-increment: cos; padding-left: 36px; margin-bottom: 12px; font-size: 0.94rem; color: var(--silver); line-height: 1.5; }
  .cos-order li::before { content: counter(cos); position: absolute; left: 0; top: -1px; width: 24px; height: 24px; border-radius: 50%; display: grid; place-items: center; font-size: 0.78rem; font-weight: 800; color: #fff; background: rgba(37, 99, 212, 0.28); border: 1px solid rgba(63, 122, 224, 0.5); }
  .cos-facts { display: flex; flex-direction: column; gap: 12px; }
  .cos-fact { background: rgba(255, 255, 255, 0.035); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: var(--r); padding: 16px 18px; }
  .cos-fact__k { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--cobalt-light); }
  .cos-fact__v { font-size: 0.9rem; color: var(--silver); line-height: 1.6; margin-top: 6px; }

  /* Block 4 — regulatory panel */
  .cos-markets { background: rgba(37, 99, 212, 0.1); border: 1px solid rgba(63, 122, 224, 0.28); border-radius: var(--r-xl); padding: clamp(22px, 3vw, 34px); }
  .cos-markets__body { font-size: 0.98rem; color: var(--silver-bright); line-height: 1.7; margin-top: 12px; max-width: 82ch; }
  .cos-reglist { display: grid; grid-template-columns: 1fr 1fr; gap: 12px 28px; margin-top: 20px; }
  .cos-reglist li { display: flex; gap: 11px; align-items: flex-start; font-size: 0.92rem; color: var(--silver-bright); line-height: 1.5; }
  .cos-reglist svg { color: var(--cobalt-light); flex-shrink: 0; margin-top: 2px; }

  /* Block 5 — ecosystem */
  .cos-eco { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 22px; }
  .cos-eco__item { background: rgba(255, 255, 255, 0.035); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: var(--r-lg); padding: 20px; }
  .cos-eco__t { font-size: 1rem; font-weight: 800; color: #fff; }
  .cos-eco__d { font-size: 0.88rem; color: var(--silver); line-height: 1.6; margin-top: 8px; }

  /* Block 6 — differentiator checklist */
  .cos-scope { display: grid; grid-template-columns: 1fr 1fr; gap: 12px 28px; margin-top: 22px; }
  .cos-scope li { display: flex; gap: 12px; align-items: flex-start; font-size: 0.94rem; color: var(--silver); line-height: 1.5; }
  .cos-scope svg { color: var(--cobalt-light); flex-shrink: 0; margin-top: 2px; }

  /* Block 7 — CTA band */
  .cos-ctaband { text-align: center; padding: clamp(28px, 4vw, 44px) 0 4px; border-top: 1px solid rgba(255, 255, 255, 0.1); }
  .cos-ctaband__t { font-size: clamp(1.4rem, 2.6vw, 2rem); font-weight: 800; letter-spacing: -0.01em; color: #fff; max-width: 24ch; margin: 0 auto; }
  .cos-ctaband__d { font-size: 1rem; color: var(--silver); line-height: 1.6; margin: 14px auto 24px; max-width: 60ch; }
  .cos-ctaband .cos-btns { justify-content: center; }

  @media (max-width: 900px) {
    .cos-two { grid-template-columns: 1fr; }
    .cos-models { grid-template-columns: 1fr; }
    .cos-cards { grid-template-columns: 1fr 1fr; }
    .cos-eco { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .cos-cards { grid-template-columns: 1fr; }
    .cos-eco { grid-template-columns: 1fr; }
    .cos-reglist { grid-template-columns: 1fr; }
    .cos-scope { grid-template-columns: 1fr; }
  }
</style>
