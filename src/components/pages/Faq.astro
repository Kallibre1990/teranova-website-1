---
import PageHead from './PageHead.astro';
import Atmosphere from '../visual/Atmosphere.astro';
import { anchorHref } from '../../i18n/utils';
import { ui, type Lang } from '../../i18n/ui';
interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
const p = t.pages.faq;
---

<PageHead sup={t.nav.faq} title={p.title} sub={p.sub} />

<section class="section section--navy">
  <Atmosphere variant="dark" />
  <div class="wrap faq">
    {
      p.items.map((it, i) => (
        <details class="faq__item" open={i === 0}>
          <summary>
            <span>{it.q}</span>
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <p>{it.a}</p>
        </details>
      ))
    }
    <div class="page-cta">
      <a class="btn btn--primary btn--lg" href={anchorHref('ondemand', lang)}>{t.common.cta_request}</a>
    </div>
  </div>
</section>

<style>
  .faq { max-width: 820px; }
  .faq__item { border: 1px solid rgba(255, 255, 255, 0.1); border-radius: var(--r); background: rgba(255, 255, 255, 0.035); margin-bottom: 12px; padding: 0 22px; }
  .faq__item summary { display: flex; align-items: center; justify-content: space-between; gap: 16px; cursor: pointer; list-style: none; padding: 20px 0; font-size: 1.04rem; font-weight: 700; color: #fff; }
  .faq__item summary::-webkit-details-marker { display: none; }
  .faq__item summary svg { flex: none; color: var(--cobalt-light); transition: transform .25s var(--ease); }
  .faq__item[open] summary svg { transform: rotate(180deg); }
  .faq__item p { font-size: 0.96rem; color: var(--silver); line-height: 1.7; padding: 0 0 20px; max-width: 70ch; }
</style>
