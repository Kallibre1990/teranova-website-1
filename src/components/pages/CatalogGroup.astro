---
import PageHead from './PageHead.astro';
import Atmosphere from '../visual/Atmosphere.astro';
import { localizePath, anchorHref } from '../../i18n/utils';
import { ui, type Lang } from '../../i18n/ui';
import type { CategoryKey } from '../../data/site';
interface Props {
  lang: Lang;
  groupKey: CategoryKey;
}
const { lang, groupKey } = Astro.props;
const t = ui[lang];
const g = t.pages.group;
const group = t.categories.groups.find((x) => x.key === groupKey)!;
const subs = group.items;

const demo = [
  { cls: 'badge--visited', label: t.verify.card_visited_t, nm: g.sample_a, role: g.role_maker, tags: [subs[0], subs[1]] },
  { cls: 'badge--provided', label: t.verify.card_provided_t, nm: g.sample_b, role: g.role_oem, tags: [subs[2] ?? subs[0]] },
  { cls: 'badge--provided', label: t.verify.card_provided_t, nm: g.sample_c, role: g.role_exporter, tags: [subs[3] ?? subs[1]] },
];
---

<PageHead sup={t.categories.sup} title={group.name} sub={group.blurb} />

<section class="section section--navy group">
  <Atmosphere variant="dark" />
  <div class="wrap">
    <a class="back" href={localizePath('/catalog', lang)}>
      <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M11 6l-6 6 6 6"/></svg>
      {g.back}
    </a>

    <div class="group__head">
      <p class="lvl" style="margin:0">{g.products_title}</p>
      <span class="badge badge--provided">{g.demo_badge}</span>
    </div>
    <div class="prod-grid">
      {
        subs.map((s) => (
          <article class="pcard">
            <span class="pcard__ic" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8 12 3 3 8l9 5 9-5ZM3 8v8l9 5 9-5V8M12 13v8"/></svg>
            </span>
            <span class="pcard__nm">{s}</span>
          </article>
        ))
      }
    </div>

    <div class="group__head">
      <p class="lvl" style="margin:0">{g.suppliers_title}</p>
      <span class="badge badge--provided">{g.demo_badge}</span>
    </div>
    <div class="sup-grid">
      {
        demo.map((s) => (
          <article class="scard">
            <span class={`badge ${s.cls}`}><span class="dot" />{s.label}</span>
            <h3 class="scard__nm">{s.nm}</h3>
            <p class="scard__role">{s.role}</p>
            <div class="scard__tags">{s.tags.map((tag) => <span>{tag}</span>)}</div>
          </article>
        ))
      }
    </div>

    <div class="group__foot">
      <span class="note">{g.demo_note}</span>
      <a class="btn btn--primary" href={anchorHref('ondemand', lang)}>{g.request}</a>
    </div>
  </div>
</section>

<style>
  .back { display: inline-flex; align-items: center; gap: 7px; font-size: 0.86rem; font-weight: 700; color: var(--cobalt-light); margin-bottom: 26px; }
  .lvl { font-size: 0.74rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--silver-muted); margin-bottom: 12px; }
  .prod-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 40px; }
  .pcard { display: flex; align-items: center; gap: 12px; background: rgba(255, 255, 255, 0.035); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: var(--r); padding: 14px 16px; }
  .pcard__ic { width: 34px; height: 34px; flex: none; border-radius: 9px; display: grid; place-items: center; background: rgba(37, 99, 212, 0.16); border: 1px solid rgba(63, 122, 224, 0.3); color: var(--cobalt-light); }
  .pcard__ic svg { width: 18px; height: 18px; }
  .pcard__nm { font-size: 0.9rem; font-weight: 600; color: var(--silver-bright); line-height: 1.3; }
  .group__head { display: flex; align-items: center; justify-content: space-between; gap: 14px; margin-bottom: 16px; }
  .sup-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .scard { background: rgba(255, 255, 255, 0.035); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: var(--r-lg); padding: 22px; }
  .scard__nm { font-size: 1.02rem; font-weight: 800; color: #fff; margin: 4px 0 4px; }
  .scard__role { font-size: 0.84rem; color: var(--silver-muted); }
  .scard__tags { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 14px; }
  .scard__tags span { font-size: 0.74rem; font-weight: 600; color: var(--silver-muted); background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 100px; padding: 4px 10px; }
  .group__foot { margin-top: 28px; display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .group__foot .note { font-size: 0.84rem; color: var(--silver-muted); max-width: 48ch; }
  @media (max-width: 820px) { .sup-grid { grid-template-columns: 1fr; } .prod-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 480px) { .prod-grid { grid-template-columns: 1fr; } }
</style>
