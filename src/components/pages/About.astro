---
import PageHead from './PageHead.astro';
import Atmosphere from '../visual/Atmosphere.astro';
import { Image } from 'astro:assets';
import { anchorHref } from '../../i18n/utils';
import { ui, type Lang } from '../../i18n/ui';
import { teamPhoto } from '../../data/teamPhotos';
import { assetPhoto } from '../../data/assetPhoto';
interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
const p = t.pages.about;
const team = t.pages.team;
const founder = team.members[0];
const banner = assetPhoto('about', 'about-hero');
---

<PageHead sup={t.nav.about} title={p.title} sub={p.sub} />

<section class="section section--navy">
  <Atmosphere variant="dark" />
  <div class="wrap">
    {banner && (
      <figure class="about-banner">
        <Image src={banner} alt={p.who_title} widths={[800, 1280, 1600]} sizes="(max-width: 1100px) 92vw, 1040px" format="webp" loading="eager" decoding="async" />
      </figure>
    )}
    <div class="about-hero">
      <div class="about-hero__text">
        <h2 class="about-hero__h">{p.who_title}</h2>
        <p class="about-hero__body">{p.who_body}</p>
      </div>
      <figure class="about-hero__media">
        <Image src={teamPhoto(founder.photo)} alt={founder.name} widths={[340, 680]} sizes="(max-width: 820px) 92vw, 340px" format="webp" loading="lazy" decoding="async" />
        <figcaption class="about-hero__cap">{founder.name} · {founder.role}</figcaption>
      </figure>
    </div>

    <div class="card-grid card-grid--2">
      <article class="icard">
        <h2 class="icard__t">{p.onsite_title}</h2>
        <p class="icard__d">{t.presence.onsite_lead}</p>
        <ul class="chips">{t.presence.countries.map((c) => <li>{c}</li>)}</ul>
        <p class="icard__d" style="margin-top:12px">{t.presence.other}</p>
      </article>
      <article class="icard">
        <h2 class="icard__t">{p.markets_title}</h2>
        <p class="icard__d">{t.presence.buyers_lead}</p>
        <ul class="chips chips--cobalt">{t.presence.buyers_regions.map((r) => <li>{r}</li>)}</ul>
      </article>
    </div>

    <div class="about-team" id="team">
      <div class="about-team__head">
        <span class="sup sup--light">( {t.nav.team} )</span>
        <h2 class="h-section">{team.title}</h2>
        <p class="sub-section">{team.sub}</p>
      </div>
      <div class="team-grid">
        {
          team.members.map((m) => (
            <figure class="tcard">
              <div class="tcard__photo">
                <Image src={teamPhoto(m.photo)} alt={`${m.name} — ${m.role}`} widths={[260, 520]} sizes="(max-width: 460px) 92vw, (max-width: 920px) 46vw, 260px" format="webp" loading="lazy" decoding="async" />
              </div>
              <figcaption class="tcard__body">
                <span class="tcard__name">{m.name}</span>
                <span class="tcard__role">{m.role}</span>
                <p class="tcard__bio">{m.bio}</p>
              </figcaption>
            </figure>
          ))
        }
      </div>
      <p class="page-note">{team.note}</p>
    </div>

    <p class="page-note">{t.footer.joint_brand}</p>
    <div class="page-cta">
      <a class="btn btn--primary btn--lg" href={anchorHref('ondemand', lang)}>{t.common.cta_request}</a>
    </div>
  </div>
</section>

<style>
  .about-banner { margin: 0 0 34px; }
  .about-banner :global(img) { width: 100%; aspect-ratio: 16 / 10; object-fit: cover; border-radius: var(--r-xl); border: 1px solid rgba(255, 255, 255, 0.14); box-shadow: var(--sh-l); display: block; }

  .about-hero { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 44px; align-items: center; margin-bottom: 30px; }
  .about-hero__h { font-size: 1.5rem; font-weight: 800; letter-spacing: -0.01em; color: #fff; margin-bottom: 14px; }
  .about-hero__body { font-size: 1.02rem; color: var(--silver); line-height: 1.7; }
  .about-hero__media { margin: 0; }
  .about-hero__media :global(img) {
    width: 100%; max-width: 340px; height: auto; border-radius: var(--r-lg);
    border: 1px solid rgba(255, 255, 255, 0.14); box-shadow: var(--sh-l); margin-left: auto; display: block;
  }
  .about-hero__cap { margin-top: 12px; font-size: 0.82rem; color: var(--silver-muted); text-align: right; }

  .chips { display: flex; flex-wrap: wrap; gap: 9px; margin-top: 14px; }
  .chips li { font-size: 0.88rem; font-weight: 600; color: var(--silver-bright); background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(255, 255, 255, 0.12); border-radius: 100px; padding: 6px 14px; }
  .chips--cobalt li { color: var(--cobalt-light); background: rgba(37, 99, 212, 0.14); border-color: rgba(63, 122, 224, 0.3); }

  /* team section */
  .about-team { margin-top: clamp(48px, 7vw, 80px); scroll-margin-top: calc(var(--nav-h) + 12px); }
  .about-team__head { max-width: 760px; margin-bottom: 28px; }
  .team-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; }
  .tcard {
    display: flex; flex-direction: column; overflow: hidden;
    background: rgba(255, 255, 255, 0.035); border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--r-lg);
  }
  .tcard__photo { aspect-ratio: 4 / 5; background: var(--navy-2); }
  .tcard__photo :global(img) { width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block; }
  .tcard__body { padding: 18px 18px 22px; display: flex; flex-direction: column; }
  .tcard__name { font-size: 1.06rem; font-weight: 800; color: #fff; letter-spacing: -0.01em; }
  .tcard__role { font-size: 0.82rem; font-weight: 700; color: var(--cobalt-light); letter-spacing: 0.02em; margin-top: 4px; }
  .tcard__bio { font-size: 0.9rem; color: var(--silver); line-height: 1.6; margin-top: 12px; }

  @media (max-width: 920px) {
    .about-hero { grid-template-columns: 1fr; gap: 24px; }
    .about-hero__media :global(img) { margin: 0 auto; }
    .about-hero__cap { text-align: center; }
    .team-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 460px) { .team-grid { grid-template-columns: 1fr; } }
</style>
