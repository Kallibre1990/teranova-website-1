---
import { localizePath } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  variant?: 'light' | 'dark';
}
const { lang, variant = 'light' } = Astro.props;
const home = localizePath('/', lang);
---

<a class:list={['logo', `logo--${variant}`]} href={home} aria-label="Teranova Group">
  <span class="logo__mark" aria-hidden="true">
    <svg viewBox="0 0 48 48" width="38" height="38" fill="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="lg-tile" x1="2" y1="2" x2="46" y2="46" gradientUnits="userSpaceOnUse">
          <stop stop-color="#3F7AE0"></stop>
          <stop offset="1" stop-color="#0B1B35"></stop>
        </linearGradient>
      </defs>
      <rect x="2" y="2" width="44" height="44" rx="12" fill="url(#lg-tile)"></rect>
      <rect x="22.5" y="13" width="4.8" height="24" rx="2.4" fill="#3F7AE0" opacity="0.55"></rect>
      <rect x="11" y="13" width="26" height="4.8" rx="2.4" fill="#EDF1F6"></rect>
      <rect x="21.6" y="13" width="4.8" height="23" rx="2.4" fill="#EDF1F6"></rect>
    </svg>
  </span>
  <span class="logo__word">
    <span class="logo__name">Teranova</span><span class="logo__sub">Group</span>
  </span>
</a>

<style>
  .logo { display: inline-flex; align-items: center; gap: 11px; flex-shrink: 0; }
  .logo__mark { display: inline-flex; line-height: 0; }
  .logo__mark svg { filter: drop-shadow(0 3px 8px rgba(11, 27, 53, 0.25)); }
  .logo__word {
    display: inline-flex; align-items: baseline; gap: 7px;
    font-size: 1.22rem; font-weight: 800; letter-spacing: -0.01em; line-height: 1;
  }
  .logo__sub { font-weight: 600; letter-spacing: 0.01em; }
  .logo--light .logo__name { color: #fff; }
  .logo--light .logo__sub { color: var(--cobalt-light); }
  .logo--dark .logo__name { color: var(--navy); }
  .logo--dark .logo__sub { color: var(--cobalt); }
  @media (max-width: 380px) {
    .logo__word { font-size: 1.08rem; }
  }
</style>
