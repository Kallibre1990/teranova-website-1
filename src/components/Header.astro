---
import Logo from './Logo.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { localizePath, anchorHref } from '../i18n/utils';
import { ui, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  path: string;
}
const { lang, path } = Astro.props;
const t = ui[lang];

const nav = [
  { label: t.nav.catalog, href: localizePath('/catalog', lang) },
  { label: t.nav.buyers, href: localizePath('/buyers', lang) },
  { label: t.nav.suppliers, href: localizePath('/suppliers', lang) },
  { label: t.nav.verify, href: localizePath('/how-we-verify', lang) },
  { label: t.nav.team, href: localizePath('/team', lang) },
  { label: t.nav.contacts, href: localizePath('/contacts', lang) },
];
const ctaHref = anchorHref('ondemand', lang);
---

<header class="site-header">
  <div class="wrap header__row">
    <Logo lang={lang} variant="light" />

    <nav class="header__nav" aria-label="Primary">
      {nav.map((i) => <a href={i.href}>{i.label}</a>)}
    </nav>

    <div class="header__right">
      <LanguageSwitcher lang={lang} path={path} />
      <a class="btn btn--primary header__cta" href={ctaHref}>{t.common.cta_request}</a>
      <button class="burger" id="navToggle" aria-label={t.common.menu} aria-expanded="false" aria-controls="mobileMenu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<div class="mobile-menu" id="mobileMenu" aria-hidden="true">
  <div class="mobile-menu__top wrap">
    <Logo lang={lang} variant="light" />
    <button class="menu-close" id="menuClose" aria-label={t.common.close}>&times;</button>
  </div>
  <nav class="mobile-menu__nav wrap" aria-label="Mobile">
    {nav.map((i) => <a href={i.href}>{i.label}</a>)}
  </nav>
  <div class="mobile-menu__foot wrap">
    <a class="btn btn--primary" href={ctaHref}>{t.common.cta_request}</a>
    <LanguageSwitcher lang={lang} path={path} />
  </div>
</div>

<style>
  .site-header {
    position: sticky; top: 0; z-index: 100;
    background: rgba(11, 27, 53, 0.86);
    backdrop-filter: saturate(160%) blur(12px);
    -webkit-backdrop-filter: saturate(160%) blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    transition: background .3s var(--ease), border-color .3s var(--ease);
  }
  .site-header.scrolled {
    background: rgba(8, 19, 37, 0.94);
    border-bottom-color: rgba(255, 255, 255, 0.1);
  }
  .header__row { height: var(--nav-h); display: flex; align-items: center; justify-content: space-between; gap: 20px; }
  .header__nav { display: flex; align-items: center; gap: 2px; flex: 1; justify-content: center; }
  .header__nav a {
    font-size: 0.84rem; font-weight: 500; color: rgba(255, 255, 255, 0.72);
    padding: 8px 12px; border-radius: 7px; white-space: nowrap;
    transition: color .2s, background .2s;
  }
  .header__nav a:hover { color: #fff; background: rgba(255, 255, 255, 0.07); }
  .header__right { display: flex; align-items: center; gap: 12px; flex-shrink: 0; }
  .header__cta { padding: 9px 17px; font-size: 0.84rem; }

  .burger { display: none; flex-direction: column; gap: 5px; padding: 8px; background: none; border: none; }
  .burger span { display: block; width: 22px; height: 2px; border-radius: 2px; background: #fff; transition: transform .3s var(--ease), opacity .2s; }

  .mobile-menu {
    position: fixed; inset: 0; z-index: 300; background: var(--navy);
    display: flex; flex-direction: column; overflow-y: auto;
    transform: translateX(100%); transition: transform .35s var(--ease);
    visibility: hidden;
  }
  .mobile-menu.open { transform: none; visibility: visible; }
  .mobile-menu__top { height: var(--nav-h); display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(255, 255, 255, 0.08); }
  .menu-close { background: none; border: none; color: #fff; font-size: 2rem; line-height: 1; padding: 4px 8px; }
  .mobile-menu__nav { display: flex; flex-direction: column; padding-top: 8px; padding-bottom: 8px; flex: 1; }
  .mobile-menu__nav a {
    font-size: 1.05rem; font-weight: 500; color: rgba(255, 255, 255, 0.85);
    padding: 15px 0; border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }
  .mobile-menu__nav a:hover { color: #fff; }
  .mobile-menu__foot { display: flex; flex-direction: column; gap: 16px; padding-top: 22px; padding-bottom: 34px; align-items: flex-start; }
  .mobile-menu__foot .btn { width: 100%; }

  @media (max-width: 1040px) {
    .header__nav { display: none; }
    .header__cta { display: none; }
    .header__right > :global(.langs) { display: none; }
    .burger { display: flex; }
  }

  /* Touch / small screens: a sticky backdrop-blur header re-rasterises every scroll
     frame — the single biggest mobile scroll-jank source. Drop it for a solid navy. */
  @media (hover: none), (max-width: 860px) {
    .site-header { backdrop-filter: none; -webkit-backdrop-filter: none; background: rgba(8, 19, 37, 0.97); }
    .site-header.scrolled { background: rgba(8, 19, 37, 0.99); }
  }
</style>

<script>
  const btn = document.getElementById('navToggle');
  const menu = document.getElementById('mobileMenu');
  const closeBtn = document.getElementById('menuClose');
  const header = document.querySelector('.site-header');

  function setOpen(open: boolean) {
    if (!menu || !btn) return;
    menu.classList.toggle('open', open);
    menu.setAttribute('aria-hidden', String(!open));
    btn.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';
  }

  btn?.addEventListener('click', () => setOpen(true));
  closeBtn?.addEventListener('click', () => setOpen(false));
  menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });

  const onScroll = () => header?.classList.toggle('scrolled', window.scrollY > 8);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
