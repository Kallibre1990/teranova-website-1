---
import Atmosphere from '../visual/Atmosphere.astro';
import { localizePath } from '../../i18n/utils';
import { ui, type Lang } from '../../i18n/ui';
import { leadCategoryValues } from '../../data/site';
interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
---

<section class="section section--navy ondemand" id="ondemand">
  <Atmosphere variant="dark" />
  <div class="wrap ondemand__grid">
    <div class="ondemand__intro" data-reveal>
      <span class="sup sup--light">( {t.ondemand.sup} )</span>
      <h2 class="h-section" data-reveal="mask">{t.ondemand.title}</h2>
      <p class="sub-section">{t.ondemand.sub}</p>
      <ul class="ondemand__points">
        {
          t.ondemand.points.map((p) => (
            <li>
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m5 12 5 5L20 7"/></svg>
              <span>{p}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="ondemand__formwrap" data-reveal data-delay="1">
      <h3 class="ondemand__form-title">{t.ondemand.form_title}</h3>
      <form class="oform" data-lead data-thanks={localizePath('/thanks', lang)} data-msg-need={t.form.err_need} data-msg-contact={t.form.err_contact} data-msg-email={t.form.err_email} data-msg-phone={t.form.err_phone} novalidate>
        <input class="oform__hp" type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <input type="hidden" name="lang" value={lang} />
        <input type="hidden" name="page" value={Astro.url.pathname} />
        <input type="hidden" name="source" value="website-form" />
        <div class="oform__grid">
          <div class="fgrp">
            <label for="od-company">{t.form.company}</label>
            <input id="od-company" name="company" type="text" placeholder={t.form.ph_company} autocomplete="organization" />
          </div>
          <div class="fgrp">
            <label for="od-contact">{t.form.contact}</label>
            <input id="od-contact" name="contact" type="text" placeholder={t.form.ph_contact} autocomplete="name" />
          </div>
          <div class="fgrp">
            <label for="od-email">{t.form.email} <span class="req">*</span></label>
            <input id="od-email" name="email" type="email" placeholder={t.form.ph_email} autocomplete="email" />
          </div>
          <div class="fgrp">
            <label for="od-phone">{t.form.phone} <span class="req">*</span></label>
            <input id="od-phone" name="phone" type="text" placeholder={t.form.ph_phone} autocomplete="tel" />
          </div>
          <div class="fgrp fgrp--full">
            <label for="od-category">{t.form.category}</label>
            <select id="od-category" name="category">
              <option value="">{t.form.category_ph}</option>
              {leadCategoryValues.map((v, i) => <option value={v}>{t.form.categories[i]}</option>)}
            </select>
          </div>
          <div class="fgrp fgrp--full">
            <label for="od-need">{t.form.need} <span class="req">*</span></label>
            <input id="od-need" name="need" type="text" placeholder={t.form.ph_need} />
          </div>
          <div class="fgrp">
            <label for="od-volume">{t.form.volume}</label>
            <input id="od-volume" name="volume" type="text" placeholder={t.form.ph_volume} />
          </div>
          <div class="fgrp">
            <label for="od-timeline">{t.form.timeline}</label>
            <input id="od-timeline" name="timeline" type="text" placeholder={t.form.ph_timeline} />
          </div>
          <div class="fgrp fgrp--full">
            <label for="od-comment">{t.form.comment}</label>
            <textarea id="od-comment" name="comment" rows="3" placeholder={t.form.ph_comment}></textarea>
          </div>
        </div>
        <p class="oform__err" data-err="msg" hidden></p>
        <p class="oform__err" data-err="network" hidden>{t.form.err_network} <a href="mailto:info@teranovagroup.com">info@teranovagroup.com</a></p>
        <button class="btn btn--primary oform__submit" type="submit">{t.form.submit}</button>
        <p class="oform__hint">{t.form.req_note}</p>
      </form>
    </div>
  </div>
</section>

<script>
  import '../../scripts/leadForm';
</script>

<style>
  .ondemand { position: relative; }
  .ondemand__grid { position: relative; z-index: 2; display: grid; grid-template-columns: 1fr 1.05fr; gap: 56px; align-items: start; }
  .ondemand__points { display: flex; flex-direction: column; gap: 13px; margin-top: 28px; }
  .ondemand__points li { display: flex; gap: 12px; align-items: flex-start; font-size: 0.98rem; color: var(--silver); line-height: 1.5; }
  .ondemand__points svg { color: var(--cobalt-light); flex-shrink: 0; margin-top: 2px; }

  .ondemand__formwrap { background: var(--surface); color: var(--ink); border-radius: var(--r-xl); padding: clamp(24px, 3vw, 36px); box-shadow: var(--sh-l); }
  .ondemand__form-title { font-size: 1.3rem; font-weight: 800; letter-spacing: -0.01em; margin-bottom: 22px; }
  .oform__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .fgrp { display: flex; flex-direction: column; gap: 6px; }
  .fgrp--full { grid-column: 1 / -1; }
  .fgrp label { font-size: 0.8rem; font-weight: 700; color: var(--ink); }
  .req { color: var(--cobalt); }
  .oform input, .oform textarea, .oform select { border: 1px solid var(--line-2); border-radius: var(--r); background: #fff; padding: 11px 13px; font-size: 0.92rem; color: var(--ink); width: 100%; transition: border-color .2s, box-shadow .2s; }
  .oform input::placeholder, .oform textarea::placeholder { color: #a9b6c8; }
  .oform input:focus, .oform textarea:focus, .oform select:focus { outline: none; border-color: var(--cobalt); box-shadow: 0 0 0 3px var(--cobalt-soft); }
  .oform .is-error, .oform .is-error:focus { border-color: #d1495b; box-shadow: 0 0 0 3px rgba(209, 73, 91, 0.15); }
  .oform textarea { resize: vertical; min-height: 84px; }
  .oform__hp { position: absolute !important; left: -9999px; width: 1px; height: 1px; opacity: 0; pointer-events: none; }
  .oform__submit { width: 100%; margin-top: 20px; }
  .oform__err { font-size: 0.84rem; color: #d1495b; line-height: 1.5; margin-top: 12px; }
  .oform__err a { color: var(--cobalt); font-weight: 600; }
  .oform__hint { font-size: 0.78rem; color: var(--faint); line-height: 1.5; margin-top: 12px; }

  @media (max-width: 880px) { .ondemand__grid { grid-template-columns: 1fr; gap: 36px; } }
  @media (max-width: 600px) { .oform input, .oform textarea { font-size: 16px; } }
  @media (max-width: 460px) { .oform__grid { grid-template-columns: 1fr; } }
</style>
