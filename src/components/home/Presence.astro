---
import { ui, type Lang } from '../../i18n/ui';
interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
---

<section class="section section--field presence" id="presence">
  <div class="wrap">
    <div class="section-head" data-reveal>
      <span class="sup">( {t.presence.sup} )</span>
      <h2 class="h-section">{t.presence.title}</h2>
    </div>

    <div class="presence__block" data-reveal>
      <p class="presence__lead">{t.presence.onsite_lead}</p>
      <ul class="presence__countries">
        {
          t.presence.countries.map((c) => (
            <li>
              <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21s7-5.5 7-11a7 7 0 1 0-14 0c0 5.5 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg>
              {c}
            </li>
          ))
        }
      </ul>
      <p class="presence__other">{t.presence.other}</p>
    </div>

    <div class="presence__buyers" data-reveal data-delay="1">
      <p class="presence__lead">{t.presence.buyers_lead}</p>
      <ul class="presence__regions">
        {t.presence.buyers_regions.map((r) => <li>{r}</li>)}
      </ul>
    </div>
  </div>
</section>

<style>
  .presence__block {
    background: var(--surface); border: 1px solid var(--line); border-radius: var(--r-xl);
    padding: clamp(26px, 4vw, 40px); box-shadow: var(--sh-s);
  }
  .presence__lead { font-size: 1.05rem; color: var(--sub); line-height: 1.65; max-width: 70ch; }
  .presence__countries { display: flex; flex-wrap: wrap; gap: 12px; margin: 22px 0 18px; }
  .presence__countries li {
    display: inline-flex; align-items: center; gap: 9px; font-size: 1.05rem; font-weight: 700; color: var(--ink);
    background: var(--panel); border: 1px solid var(--line-2); border-radius: 100px; padding: 10px 18px;
  }
  .presence__countries svg { color: var(--cobalt); }
  .presence__other { font-size: 0.92rem; color: var(--faint); }

  .presence__buyers { margin-top: 26px; display: flex; flex-wrap: wrap; align-items: center; gap: 12px 18px; }
  .presence__buyers .presence__lead { font-size: 0.98rem; }
  .presence__regions { display: flex; flex-wrap: wrap; gap: 8px; }
  .presence__regions li {
    font-size: 0.82rem; font-weight: 700; letter-spacing: 0.03em; color: var(--cobalt);
    background: var(--cobalt-soft); border-radius: 100px; padding: 6px 14px;
  }
</style>
