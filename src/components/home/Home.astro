---
import Hero from './Hero.astro';
import Marquee from '../Marquee.astro';
import Categories from './Categories.astro';
import Verify from './Verify.astro';
import AboutHome from './AboutHome.astro';
import OnDemand from './OnDemand.astro';
import Presence from './Presence.astro';
import HowItWorks from './HowItWorks.astro';
import TendersHome from './TendersHome.astro';
import TeamTeaser from './TeamTeaser.astro';
import CtaSection from './CtaSection.astro';
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
---

<Hero lang={lang} />
<Marquee lang={lang} />
<Categories lang={lang} />
<Verify lang={lang} />
<AboutHome lang={lang} />
<OnDemand lang={lang} />
<Presence lang={lang} />
<HowItWorks lang={lang} />
<TendersHome lang={lang} />
<TeamTeaser lang={lang} />
<CtaSection lang={lang} />
