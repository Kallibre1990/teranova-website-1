---
import Atmosphere from '../visual/Atmosphere.astro';
import { localizePath } from '../../i18n/utils';
import { ui, type Lang } from '../../i18n/ui';
import CategoryArt from '../visual/CategoryArt.astro';
interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
// «Смежные направления» — последней карточкой.
const groups = [...t.categories.groups.filter((g) => g.key !== 'adjacent'), ...t.categories.groups.filter((g) => g.key === 'adjacent')];

const icons: Record<string, string> = {
  marine: '<circle cx="12" cy="5" r="2.4"/><path d="M12 7.4V21M5 13a7 7 0 0 0 14 0M3.5 13H7M17 13h3.5"/>',
  cosmetics: '<path d="M12 3c3.5 4.2 6 7.2 6 10.5a6 6 0 1 1-12 0C6 10.2 8.5 7.2 12 3Z"/>',
  medical: '<path d="M3 12h4l2 5 4-12 2 7h6"/>',
  industrial: '<circle cx="12" cy="12" r="3.2"/><path d="M12 2v3M12 19v3M4.2 4.2l2.1 2.1M17.7 17.7l2.1 2.1M2 12h3M19 12h3M4.2 19.8l2.1-2.1M17.7 6.3l2.1-2.1"/>',
  transport: '<path d="M3 16V6h11v10M14 9h4l3 3v4h-2M3 16h9M7.5 18.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3ZM17.5 18.5a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z"/>',
  adjacent: '<rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/>',
  chemical: '<path d="M9 3h6M10 3v6l-5 8.5A2 2 0 0 0 7 21h10a2 2 0 0 0 1.7-3.2L14 9V3"/><path d="M7.5 14h9"/>',
};
---

<section class="section section--navy categories" id="categories">
  <Atmosphere variant="dark" />
  <div class="wrap">
    <div class="section-head">
      <span class="sup">( {t.categories.sup} )</span>
      <h2 class="h-section">{t.categories.title}</h2>
      <p class="sub-section">{t.categories.sub}</p>
    </div>

    <div class="cat-carousel" data-carousel>
      <div class="cat-track" data-carousel-track>
        {
          groups.map((g, i) => (
            <a class="cat" href={localizePath(`/catalog/${g.key}`, lang)}>
              <CategoryArt categoryKey={g.key} />
              <div class="cat__top">
                <span class="cat__icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={icons[g.key] ?? icons.adjacent} />
                </span>
                <span class="cat__num">{String(i + 1).padStart(2, '0')}</span>
              </div>
              <h3 class="cat__name">{g.name}</h3>
              <p class="cat__blurb">{g.blurb}</p>
              <ul class="cat__items">
                {g.items.map((it) => <li>{it}</li>)}
              </ul>
            </a>
          ))
        }
      </div>
      <button class="ccar-btn ccar-btn--prev" data-carousel-prev type="button" aria-label={t.common.prev}>
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 6l-6 6 6 6"/></svg>
      </button>
      <button class="ccar-btn ccar-btn--next" data-carousel-next type="button" aria-label={t.common.next}>
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 6l6 6-6 6"/></svg>
      </button>
    </div>

    <p class="cat-demo">{t.categories.demo_note}</p>
  </div>
</section>

<script>
  import '../../scripts/carousel';
</script>

<style>
  .categories { position: relative; }
  .cat-carousel { position: relative; }
  .cat-track {
    display: flex; gap: 18px; overflow-x: auto; scroll-snap-type: x mandatory;
    scroll-behavior: smooth; scrollbar-width: none; -ms-overflow-style: none; padding: 4px 2px 12px;
  }
  .cat-track::-webkit-scrollbar { display: none; }
  .cat-track.is-grabbing { scroll-behavior: auto; cursor: grabbing; }
  .cat {
    flex: 0 0 clamp(252px, 76%, 290px); scroll-snap-align: start;
    position: relative; overflow: hidden;
    display: flex; flex-direction: column;
    background: rgba(255, 255, 255, 0.035); border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--r-lg); padding: 26px 24px; backdrop-filter: blur(6px);
    transition: transform .3s var(--ease), background .3s var(--ease), border-color .3s var(--ease), box-shadow .3s var(--ease);
  }
  .cat__top, .cat__name, .cat__blurb, .cat__items { position: relative; z-index: 1; }
  .cat:hover { transform: translateY(-6px); background: rgba(37, 99, 212, 0.1); border-color: rgba(63, 122, 224, 0.45); box-shadow: 0 26px 50px -24px rgba(0, 0, 0, 0.7); }
  .cat__top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
  .cat__icon { width: 50px; height: 50px; border-radius: 13px; display: grid; place-items: center; background: rgba(37, 99, 212, 0.16); border: 1px solid rgba(63, 122, 224, 0.3); color: var(--cobalt-light); transition: background .3s var(--ease), color .3s var(--ease); }
  .cat__icon svg { width: 25px; height: 25px; }
  .cat:hover .cat__icon { background: linear-gradient(140deg, var(--cobalt), var(--cobalt-light)); color: #fff; }
  .cat__num { font-size: 0.9rem; font-weight: 800; color: rgba(255, 255, 255, 0.18); }
  .cat__name { font-size: 1.12rem; font-weight: 800; letter-spacing: -0.01em; color: #fff; margin-bottom: 8px; }
  .cat__blurb { font-size: 0.88rem; color: var(--silver); line-height: 1.55; margin-bottom: 16px; }
  .cat__items { display: flex; flex-wrap: wrap; gap: 7px; margin-top: auto; }
  .cat__items li { font-size: 0.74rem; font-weight: 600; color: var(--silver-muted); background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 100px; padding: 4px 10px; }
  .cat-demo { margin-top: 22px; font-size: 0.84rem; color: var(--silver-muted); }

  .ccar-btn {
    position: absolute; top: 46%; transform: translateY(-50%);
    width: 46px; height: 46px; border-radius: 50%; background: var(--cobalt); color: #fff;
    border: none; display: grid; place-items: center; box-shadow: var(--sh-m); z-index: 3;
    transition: opacity .2s var(--ease), background .2s var(--ease);
  }
  .ccar-btn:hover { background: var(--cobalt-light); }
  .ccar-btn:disabled { opacity: 0; pointer-events: none; }
  .ccar-btn--prev { left: -8px; }
  .ccar-btn--next { right: -8px; }

  @media (hover: none) { .ccar-btn { display: none; } }
  @media (max-width: 560px) { .cat { flex-basis: 84%; } }
  /* Touch / small screens: drop backdrop-blur (a scroll-jank source). */
  @media (hover: none), (max-width: 860px) {
    .cat { backdrop-filter: none; -webkit-backdrop-filter: none; background: rgba(14, 34, 67, 0.66); }
  }
  @media (prefers-reduced-motion: reduce) { .cat-track { scroll-behavior: auto; } }
</style>
