---
import { ui, type Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
---

<section class="section section--alt how" id="how">
  <div class="wrap">
    <div class="section-head" data-reveal>
      <span class="eyebrow">{t.how.eyebrow}</span>
      <h2 class="h-section">{t.how.title}</h2>
      <p class="sub-section">{t.how.sub}</p>
    </div>

    <ol class="how__grid">
      {
        t.how.steps.map((step, i) => (
          <li class="hstep" data-reveal data-delay={(i % 4) + 1}>
            <span class="hstep__n">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="hstep__t">{step.t}</h3>
            <p class="hstep__d">{step.d}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .how__grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px;
    position: relative; counter-reset: step;
  }
  .how__grid::before {
    content: ''; position: absolute; top: 26px; left: 10%; right: 10%; height: 1px;
    background: linear-gradient(90deg, transparent, var(--line-2) 12%, var(--cobalt) 50%, var(--line-2) 88%, transparent);
  }
  .hstep { position: relative; }
  .hstep__n {
    display: inline-flex; align-items: center; justify-content: center;
    width: 54px; height: 54px; border-radius: 50%;
    background: var(--surface); border: 1.5px solid var(--cobalt); color: var(--cobalt);
    font-size: 1rem; font-weight: 800; margin-bottom: 20px; position: relative; z-index: 1;
    box-shadow: 0 6px 16px -8px rgba(37, 99, 212, 0.5);
  }
  .hstep__t { font-size: 1.06rem; font-weight: 800; letter-spacing: -0.01em; margin-bottom: 9px; }
  .hstep__d { font-size: 0.9rem; color: var(--sub); line-height: 1.6; }

  @media (max-width: 860px) {
    .how__grid { grid-template-columns: 1fr 1fr; gap: 32px; }
    .how__grid::before { display: none; }
  }
  @media (max-width: 460px) {
    .how__grid { grid-template-columns: 1fr; gap: 28px; }
  }
</style>
