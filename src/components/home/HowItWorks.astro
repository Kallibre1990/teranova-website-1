---
import Atmosphere from '../visual/Atmosphere.astro';
import { ui, type Lang } from '../../i18n/ui';
interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
---

<section class="section section--navy how" id="how">
  <Atmosphere variant="dark" />
  <div class="wrap">
    <div class="section-head">
      <span class="sup">( {t.how.sup} )</span>
      <h2 class="h-section">{t.how.title}</h2>
      <p class="sub-section">{t.how.sub}</p>
    </div>

    <ol class="how__grid">
      {
        t.how.steps.map((step, i) => (
          <li class="hstep">
            <span class="hstep__n">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="hstep__t">{step.t}</h3>
            <p class="hstep__d">{step.d}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .how { position: relative; }
  .how__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; position: relative; }
  .how__grid::before { content: ''; position: absolute; top: 28px; left: 16%; right: 16%; height: 1px; background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.12) 12%, var(--cobalt) 50%, rgba(255, 255, 255, 0.12) 88%, transparent); }
  .hstep { position: relative; }
  .hstep__n { display: inline-grid; place-items: center; width: 58px; height: 58px; border-radius: 50%; background: var(--navy-2); border: 1.5px solid var(--cobalt); color: var(--cobalt-light); font-size: 1.05rem; font-weight: 800; margin-bottom: 20px; position: relative; z-index: 1; box-shadow: 0 0 0 6px rgba(11, 27, 53, 0.6), 0 10px 24px -10px rgba(37, 99, 212, 0.7); }
  .hstep__t { font-size: 1.14rem; font-weight: 800; letter-spacing: -0.01em; color: #fff; margin-bottom: 9px; }
  .hstep__d { font-size: 0.92rem; color: var(--silver); line-height: 1.6; max-width: 34ch; }
  @media (max-width: 760px) { .how__grid { grid-template-columns: 1fr; gap: 26px; } .how__grid::before { display: none; } }
</style>
