---
import Atmosphere from '../visual/Atmosphere.astro';
import { localizePath } from '../../i18n/utils';
import { ui, type Lang } from '../../i18n/ui';
interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
---

<section class="section section--navy verify" id="verify">
  <Atmosphere variant="dark" />
  <div class="wrap">
    <div class="section-head">
      <span class="sup">( {t.verify.sup} )</span>
      <h2 class="h-section">{t.verify.title}</h2>
      <p class="sub-section">{t.verify.intro}</p>
    </div>

    <div class="verify__grid">
      <article class="vcard">
        <span class="badge badge--visited"><span class="dot"></span>{t.verify.card_visited_t}</span>
        <div class="vcard__icon vcard__icon--v" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 5v6c0 5 3.5 8 8 11 4.5-3 8-6 8-11V5l-8-3Z"/><path d="m9 11.5 2 2 4-4"/></svg>
        </div>
        <p class="vcard__text">{t.verify.card_visited_d}</p>
      </article>

      <article class="vcard">
        <span class="badge badge--provided"><span class="dot"></span>{t.verify.card_provided_t}</span>
        <div class="vcard__icon vcard__icon--p" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8l-5-5Z"/><path d="M14 3v5h5M9 13h6M9 17h6"/></svg>
        </div>
        <p class="vcard__text">{t.verify.card_provided_d}</p>
      </article>
    </div>

    <div class="verify__note">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 16v-4M12 8h.01"/></svg>
      <p>{t.verify.note}</p>
    </div>

    <div class="verify__more">
      <a class="link-arrow" href={localizePath('/how-we-verify', lang)}>
        {t.verify.link}
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .verify { position: relative; }
  .verify__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }
  .vcard {
    position: relative; background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--r-xl); padding: 32px; overflow: hidden; backdrop-filter: blur(6px);
  }
  .vcard::before { content: ''; position: absolute; inset: 0 0 auto 0; height: 3px; }
  .vcard:first-child::before { background: linear-gradient(90deg, var(--visited), transparent); }
  .vcard:last-child::before { background: linear-gradient(90deg, var(--provided), transparent); }
  .vcard__icon { width: 52px; height: 52px; border-radius: 14px; display: grid; place-items: center; margin: 22px 0 16px; }
  .vcard__icon svg { width: 26px; height: 26px; }
  .vcard__icon--v { background: rgba(21, 145, 108, 0.16); color: #4cd2a3; border: 1px solid rgba(21, 145, 108, 0.4); }
  .vcard__icon--p { background: rgba(154, 106, 18, 0.16); color: #e0b25e; border: 1px solid rgba(154, 106, 18, 0.4); }
  .vcard__text { font-size: 0.98rem; color: var(--silver); line-height: 1.65; }
  .verify__note { display: flex; gap: 13px; align-items: flex-start; margin-top: 26px; padding: 18px 20px; border-radius: var(--r-lg); background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(255, 255, 255, 0.1); }
  .verify__note svg { width: 20px; height: 20px; color: var(--cobalt-light); flex-shrink: 0; margin-top: 1px; }
  .verify__note p { font-size: 0.9rem; color: var(--silver); line-height: 1.6; }
  .verify__more { margin-top: 24px; }
  @media (max-width: 720px) { .verify__grid { grid-template-columns: 1fr; } }
  /* Touch / small screens: drop backdrop-blur to avoid scroll jank. */
  @media (hover: none), (max-width: 860px) {
    .vcard { backdrop-filter: none; -webkit-backdrop-filter: none; background: rgba(14, 34, 67, 0.7); }
  }
</style>
