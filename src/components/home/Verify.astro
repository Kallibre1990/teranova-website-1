---
import { localizePath } from '../../i18n/utils';
import { ui, type Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
---

<section class="section verify" id="verify">
  <div class="wrap">
    <div class="section-head" data-reveal>
      <span class="eyebrow">{t.verify.eyebrow}</span>
      <h2 class="h-section">{t.verify.title}</h2>
      <p class="sub-section">{t.verify.sub}</p>
    </div>

    <div class="verify__grid">
      <article class="vcard vcard--visited" data-reveal data-delay="1">
        <span class="badge badge--visited"><span class="dot"></span>{t.verify.card_visited_t}</span>
        <div class="vcard__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2 4 5v6c0 5 3.5 8 8 11 4.5-3 8-6 8-11V5l-8-3Z"></path>
            <path d="m9 11.5 2 2 4-4"></path>
          </svg>
        </div>
        <p class="vcard__text">{t.verify.card_visited_d}</p>
      </article>

      <article class="vcard vcard--provided" data-reveal data-delay="2">
        <span class="badge badge--provided"><span class="dot"></span>{t.verify.card_provided_t}</span>
        <div class="vcard__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8l-5-5Z"></path>
            <path d="M14 3v5h5M9 13h6M9 17h6"></path>
          </svg>
        </div>
        <p class="vcard__text">{t.verify.card_provided_d}</p>
      </article>
    </div>

    <div class="verify__note" data-reveal>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="9"></circle>
        <path d="M12 16v-4M12 8h.01"></path>
      </svg>
      <p>{t.verify.note}</p>
    </div>

    <div class="verify__more" data-reveal>
      <a class="link-arrow" href={localizePath('/how-we-verify', lang)}>
        {t.verify.link}
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .verify__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }
  .vcard {
    position: relative; background: var(--surface); border: 1px solid var(--line);
    border-radius: var(--r-xl); padding: 30px 30px 32px; box-shadow: var(--sh-s);
    overflow: hidden;
  }
  .vcard::before {
    content: ''; position: absolute; inset: 0 0 auto 0; height: 3px;
  }
  .vcard--visited::before { background: linear-gradient(90deg, var(--visited), transparent); }
  .vcard--provided::before { background: linear-gradient(90deg, var(--provided), transparent); }
  .vcard__icon {
    width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center;
    margin: 22px 0 16px;
  }
  .vcard__icon svg { width: 26px; height: 26px; }
  .vcard--visited .vcard__icon { background: var(--visited-bg); color: var(--visited); }
  .vcard--provided .vcard__icon { background: var(--provided-bg); color: var(--provided); }
  .vcard__text { font-size: 0.98rem; color: var(--sub); line-height: 1.65; }

  .verify__note {
    display: flex; gap: 13px; align-items: flex-start;
    margin-top: 26px; padding: 18px 20px; border-radius: var(--r-lg);
    background: var(--bg-alt); border: 1px solid var(--line);
  }
  .verify__note svg { width: 20px; height: 20px; color: var(--cobalt); flex-shrink: 0; margin-top: 1px; }
  .verify__note p { font-size: 0.9rem; color: var(--sub); line-height: 1.6; }
  .verify__more { margin-top: 24px; }

  @media (max-width: 720px) {
    .verify__grid { grid-template-columns: 1fr; }
  }
</style>
