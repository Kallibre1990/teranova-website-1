---
import Atmosphere from '../visual/Atmosphere.astro';
import FloorGrid from '../visual/FloorGrid.astro';
import Diamond from '../visual/Diamond.astro';
import IndustryLine from '../visual/IndustryLine.astro';
import { anchorHref } from '../../i18n/utils';
import { ui, type Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
---

<section class="hero" data-hero>
  <div class="hero__stage">
    <Atmosphere variant="hero" />
    <FloorGrid />
    <IndustryLine />
    <span class="hero__cross" data-hero-cross aria-hidden="true"></span>

    <div class="hero__diamond" data-hero-art aria-hidden="true">
      <Diamond />
    </div>

    <div class="wrap hero__content" data-hero-content>
      <span class="sup sup--light">( {t.hero.sup} )</span>
      <h1 class="hero__title"><span class="metal">{t.hero.title}</span></h1>
      <p class="hero__sub">{t.hero.sub}</p>
      <div class="hero__cta">
        <a class="btn btn--primary btn--lg" href={anchorHref('categories', lang)}>{t.hero.cta_primary}</a>
        <a class="btn btn--ghost btn--lg" href={anchorHref('ondemand', lang)}>{t.hero.cta_secondary}</a>
      </div>
    </div>

    <a class="hero__scroll" href={anchorHref('categories', lang)} aria-label={t.common.scroll}>
      <span>{t.hero.scroll_hint}</span>
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M6 13l6 6 6-6"/></svg>
    </a>
  </div>
</section>

<style>
  .hero { position: relative; color: #fff; background: var(--navy-deep); }
  .hero__stage {
    position: relative; overflow: hidden;
    min-height: min(100vh, 920px); display: flex; align-items: center; justify-content: center;
    text-align: center; padding: calc(var(--nav-h) + 40px) 0 92px;
  }
  /* Dynamic viewport height: avoids the mobile address-bar jump and keeps the
     scroll hint visible on phones (graceful fallback to 100vh above). */
  @supports (height: 100dvh) { .hero__stage { min-height: min(100dvh, 920px); } }

  .hero__diamond {
    position: absolute; top: 45%; left: 50%; transform: translate(-50%, -50%);
    width: clamp(340px, 46vw, 600px); z-index: 4; pointer-events: none;
    filter: drop-shadow(0 36px 90px rgba(37, 99, 212, 0.45));
  }
  .hero__cross { position: absolute; inset: 0; z-index: 5; opacity: 0; pointer-events: none; background: radial-gradient(82% 80% at 50% 58%, rgba(8, 18, 38, 0.55), rgba(4, 8, 18, 0.96)); }

  .hero__content { position: relative; z-index: 6; max-width: 840px; }
  .hero__content::before {
    content: ''; position: absolute; inset: -16% -10%; z-index: -1; pointer-events: none;
    background: radial-gradient(60% 58% at 50% 52%, rgba(6, 13, 28, 0.74), rgba(6, 13, 28, 0.32) 56%, transparent 78%);
  }
  .hero__title { font-size: clamp(2.5rem, 6.6vw, 5rem); font-weight: 800; line-height: 1.02; letter-spacing: -0.035em; margin: 8px auto 22px; max-width: 17ch; }
  .hero__sub { font-size: clamp(1.05rem, 1.5vw, 1.22rem); color: var(--silver); line-height: 1.65; max-width: 54ch; margin: 0 auto 32px; }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 14px; justify-content: center; }

  .hero__scroll {
    position: absolute; left: 50%; bottom: 24px; transform: translateX(-50%); z-index: 6;
    display: inline-flex; flex-direction: column; align-items: center; gap: 7px;
    font-size: 0.74rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--silver-muted);
  }
  .hero__scroll svg { animation: bob 1.8s ease-in-out infinite; }
  @keyframes bob { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(5px); } }

  @media (max-width: 720px) {
    .hero__stage { padding: calc(var(--nav-h) + 28px) 0 72px; }
    .hero__diamond { width: 84vw; top: 44%; opacity: 0.6; }
    .hero__title { font-size: clamp(2.1rem, 9vw, 3rem); }
  }
  @media (max-width: 480px) {
    .hero__cta { flex-direction: column; align-items: stretch; }
    .hero__cta .btn { width: 100%; }
  }
  @media (prefers-reduced-motion: reduce) { .hero__scroll svg { animation: none; } }
</style>
