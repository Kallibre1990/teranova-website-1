---
import Atmosphere from '../visual/Atmosphere.astro';
import Diamond from '../visual/Diamond.astro';
import { anchorHref } from '../../i18n/utils';
import { ui, type Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
---

<section class="hero">
  <div class="hero__stage">
    <Atmosphere variant="hero" />
    <span class="hero__cross" data-hero-cross aria-hidden="true"></span>

    <div class="wrap hero__grid">
      <div class="hero__content">
        <span class="sup sup--light">( {t.hero.sup} )</span>
        <h1 class="hero__title"><span class="metal">{t.hero.title}</span></h1>
        <p class="hero__sub">{t.hero.sub}</p>
        <div class="hero__cta">
          <a class="btn btn--primary btn--lg" href={anchorHref('categories', lang)}>{t.hero.cta_primary}</a>
          <a class="btn btn--ghost btn--lg" href={anchorHref('ondemand', lang)}>{t.hero.cta_secondary}</a>
        </div>
      </div>

      <div class="hero__art" data-hero-art>
        <Diamond />
      </div>
    </div>

    <a class="hero__scroll" href={anchorHref('categories', lang)} aria-label={t.common.scroll}>
      <span>{t.hero.scroll_hint}</span>
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M6 13l6 6 6-6"/></svg>
    </a>
  </div>
</section>

<style>
  .hero { position: relative; color: #fff; }
  .hero__stage {
    position: relative; overflow: hidden;
    min-height: min(100vh, 940px); display: flex; align-items: center;
    padding: calc(var(--nav-h) + 48px) 0 96px;
  }
  .hero__cross {
    position: absolute; inset: 0; z-index: 1; opacity: 0; pointer-events: none; will-change: opacity;
    background: radial-gradient(100% 100% at 18% 100%, rgba(37, 99, 212, 0.5), transparent 55%), linear-gradient(180deg, #0e2243, #081325);
  }
  .hero__grid { position: relative; z-index: 2; display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 40px; align-items: center; width: 100%; }
  .hero__content { max-width: 620px; }
  .hero__title { font-size: clamp(2.3rem, 5.6vw, 4rem); font-weight: 800; line-height: 1.06; letter-spacing: -0.03em; margin: 8px 0 22px; }
  .hero__sub { font-size: clamp(1.05rem, 1.5vw, 1.22rem); color: var(--silver); line-height: 1.7; max-width: 560px; margin-bottom: 34px; }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 14px; }
  .hero__art { position: relative; height: clamp(320px, 40vw, 500px); }

  .hero__scroll { position: absolute; left: 50%; bottom: 26px; transform: translateX(-50%); z-index: 2; display: inline-flex; flex-direction: column; align-items: center; gap: 7px; font-size: 0.74rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--silver-muted); }
  .hero__scroll svg { animation: bob 1.8s ease-in-out infinite; }
  @keyframes bob { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(5px); } }

  /* Pinned hero: sticky stage + GSAP scrub. Desktop + JS + motion only, so it
     can never break layout for no-JS / reduced-motion / mobile users. */
  @media (prefers-reduced-motion: no-preference) and (min-width: 861px) {
    html.js .hero { height: 175vh; }
    html.js .hero .hero__stage { position: sticky; top: 0; height: 100vh; min-height: 0; padding: var(--nav-h) 0 0; }
  }

  @media (max-width: 860px) {
    .hero__stage { min-height: auto; padding-top: calc(var(--nav-h) + 36px); padding-bottom: 80px; }
    .hero__grid { grid-template-columns: 1fr; }
    .hero__art { position: absolute; inset: 0; z-index: 1; height: 100%; opacity: 0.2; pointer-events: none; }
    .hero__content { position: relative; z-index: 2; }
  }
  @media (prefers-reduced-motion: reduce) { .hero__scroll svg { animation: none; } }
</style>
