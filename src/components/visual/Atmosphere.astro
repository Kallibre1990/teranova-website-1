---
/* Code-drawn atmospheric background for dark sections: deep gradient-light field
   + parallax glow + faint network/bridge motif + grain. No photos (docs/IMAGERY.md). */
interface Props {
  variant?: 'hero' | 'dark';
  class?: string;
}
const { variant = 'dark', class: cls = '' } = Astro.props;

// Deterministic network nodes + links (the "we connect two sides" motif).
const nodes = [
  [120, 140], [300, 90], [470, 180], [640, 110], [820, 200], [930, 120],
  [180, 360], [380, 300], [560, 400], [740, 330], [900, 420],
  [240, 560], [430, 620], [620, 560], [810, 640], [960, 560],
];
const links = [
  [0, 1], [1, 2], [2, 3], [3, 4], [4, 5], [0, 6], [1, 7], [2, 8], [3, 9], [4, 10],
  [6, 7], [7, 8], [8, 9], [9, 10], [6, 11], [7, 12], [8, 13], [9, 14], [10, 15],
  [11, 12], [12, 13], [13, 14], [14, 15],
];
---

<div class:list={['atmo', `atmo--${variant}`, cls]} aria-hidden="true">
  <span class="atmo__glow atmo__glow--1" data-parallax="0.12"></span>
  <span class="atmo__glow atmo__glow--2" data-parallax="0.2"></span>
  <svg class="atmo__net" viewBox="0 0 1040 720" preserveAspectRatio="xMidYMid slice" fill="none" xmlns="http://www.w3.org/2000/svg" data-parallax="0.06">
    <g stroke="#5d76a6" stroke-opacity="0.16" stroke-width="1">
      {links.map(([a, b]) => <line x1={nodes[a][0]} y1={nodes[a][1]} x2={nodes[b][0]} y2={nodes[b][1]} />)}
    </g>
    <g fill="#9fb6da" fill-opacity="0.4">
      {nodes.map(([x, y]) => <circle cx={x} cy={y} r="2.4" />)}
    </g>
  </svg>
  <span class="grain"></span>
</div>

<style>
  .atmo { position: absolute; inset: 0; overflow: hidden; pointer-events: none; z-index: 0; }
  .atmo--hero { background: radial-gradient(120% 110% at 78% -10%, #143257 0%, #0b1b35 46%, #081325 100%); }
  .atmo--dark { background: linear-gradient(180deg, #0b1b35 0%, #0e2243 100%); }
  .atmo__glow { position: absolute; border-radius: 50%; will-change: transform; }
  .atmo__glow--1 { top: -160px; right: -120px; width: 620px; height: 620px; background: radial-gradient(circle, rgba(37, 99, 212, 0.34) 0%, transparent 68%); }
  .atmo__glow--2 { bottom: -200px; left: -140px; width: 560px; height: 560px; background: radial-gradient(circle, rgba(63, 122, 224, 0.18) 0%, transparent 70%); }
  .atmo__net { position: absolute; inset: 0; width: 100%; height: 100%; opacity: 0.8; will-change: transform; }
</style>
