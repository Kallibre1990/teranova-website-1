---
/* Code-drawn layered backdrop behind section content: a navy "fabric" field
   (generated texture) + optional duotone photo (drop a file in /public/img and it
   appears, else it's simply skipped) + parallax glows + concentric-diamond contours
   + grain. No external/stock photos baked in. */
interface Props {
  variant?: 'hero' | 'dark' | 'light';
  photo?: string; // filename in /public/img, e.g. 'hero.jpg' — optional
  class?: string;
}
const { variant = 'dark', photo, class: cls = '' } = Astro.props;

const cxp = 800, cyp = 320;
const rings = [120, 230, 340, 450, 560, 680];
---

<div class:list={['atmo', `atmo--${variant}`, cls]} aria-hidden="true">
  {photo && <img class="atmo__photo" src={`/img/${photo}`} alt="" loading="lazy" decoding="async" onerror="this.remove()" />}
  <span class="atmo__glow atmo__glow--1" data-parallax="0.12"></span>
  <span class="atmo__glow atmo__glow--2" data-parallax="0.2"></span>

  <svg class="atmo__contour" viewBox="0 0 1000 640" preserveAspectRatio="xMidYMid slice" fill="none" xmlns="http://www.w3.org/2000/svg" data-parallax="0.07">
    <g class="atmo__rings">
      {rings.map((r) => <polygon points={`${cxp},${cyp - r} ${cxp + r},${cyp} ${cxp},${cyp + r} ${cxp - r},${cyp}`} />)}
    </g>
    <g class="atmo__dots">
      {Array.from({ length: 7 }).map((_, r) => Array.from({ length: 11 }).map((__, c) => <circle cx={60 + c * 92} cy={50 + r * 88} r="1.5" />))}
    </g>
  </svg>

  <span class="grain"></span>
</div>

<style>
  .atmo { position: absolute; inset: 0; overflow: hidden; pointer-events: none; z-index: 0; }
  .atmo--hero, .atmo--dark { background-color: #0b1b35; background-image: url('/img/tex-deep.webp'); background-size: cover; background-position: center; }
  .atmo--hero { background-position: 70% 0%; }
  .atmo--light { background: transparent; }

  /* optional duotone deep photo */
  .atmo__photo { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; filter: grayscale(1) brightness(0.42) contrast(1.06); opacity: 0.55; mix-blend-mode: luminosity; }
  .atmo--hero .atmo__photo, .atmo--dark .atmo__photo { -webkit-mask-image: linear-gradient(180deg, rgba(0,0,0,0.9), rgba(0,0,0,0.55)); mask-image: linear-gradient(180deg, rgba(0,0,0,0.9), rgba(0,0,0,0.55)); }

  .atmo__glow { position: absolute; border-radius: 50%; will-change: transform; }
  .atmo__glow--1 { top: -180px; right: -120px; width: 640px; height: 640px; }
  .atmo__glow--2 { bottom: -220px; left: -160px; width: 560px; height: 560px; }
  .atmo--hero .atmo__glow--1, .atmo--dark .atmo__glow--1 { background: radial-gradient(circle, rgba(37, 99, 212, 0.32) 0%, transparent 68%); }
  .atmo--hero .atmo__glow--2, .atmo--dark .atmo__glow--2 { background: radial-gradient(circle, rgba(63, 122, 224, 0.18) 0%, transparent 70%); }
  .atmo--light .atmo__glow--1 { background: radial-gradient(circle, rgba(37, 99, 212, 0.12) 0%, transparent 66%); }
  .atmo--light .atmo__glow--2 { background: radial-gradient(circle, rgba(63, 122, 224, 0.1) 0%, transparent 70%); }

  .atmo__contour { position: absolute; inset: 0; width: 100%; height: 100%; will-change: transform; }
  .atmo__rings polygon { fill: none; stroke-width: 1.2; }
  .atmo--hero .atmo__rings polygon, .atmo--dark .atmo__rings polygon { stroke: rgba(120, 147, 188, 0.16); }
  .atmo--light .atmo__rings polygon { stroke: rgba(37, 99, 212, 0.12); }
  .atmo--hero .atmo__dots circle, .atmo--dark .atmo__dots circle { fill: rgba(159, 182, 218, 0.14); }
  .atmo--light .atmo__dots circle { fill: rgba(37, 99, 212, 0.09); }
</style>
