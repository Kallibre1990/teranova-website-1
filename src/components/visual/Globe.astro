---
interface Props {
  label?: string;
}
const { label = 'Korea → world' } = Astro.props;
---

<div class="globe">
  <span class="globe__halo" aria-hidden="true"></span>
  <canvas data-globe class="globe__cv" role="img" aria-label={label}></canvas>
</div>

<script>
  import '../../scripts/globe';
</script>

<style>
  .globe { position: relative; width: 100%; aspect-ratio: 1 / 1; max-width: 430px; margin: 0 auto; }
  .globe__halo {
    position: absolute; inset: 4%; border-radius: 50%; pointer-events: none;
    background: radial-gradient(circle at 50% 45%, rgba(37, 99, 212, 0.32), transparent 62%);
    filter: blur(6px);
  }
  .globe__cv { position: relative; width: 100%; height: 100%; display: block; }
</style>
