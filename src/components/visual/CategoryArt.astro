---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
/* Real photo/illustration slot for a catalog card background.
   We do NOT draw raster here and do NOT use stock/AI by ourselves (brand rule).
   Drop a file into src/assets/catalog/<key>.(jpg|jpeg|png|webp) — it appears,
   optimised, as the card background. Nothing renders until a file is provided. */
interface Props {
  categoryKey: string;
}
const { categoryKey } = Astro.props;
const files = import.meta.glob<{ default: ImageMetadata }>('../../assets/catalog/*.{jpg,jpeg,png,webp}', { eager: true });
const byKey: Record<string, ImageMetadata> = Object.fromEntries(
  Object.entries(files).map(([p, m]) => [p.split('/').pop()!.replace(/\.[a-z]+$/i, ''), m.default]),
);
const img = byKey[categoryKey];
---

{
  img && (
    <div class="cat-art" aria-hidden="true">
      <Image src={img} alt="" widths={[320, 640]} sizes="320px" format="webp" loading="lazy" decoding="async" />
    </div>
  )
}

<style>
  .cat-art { position: absolute; inset: 0; z-index: 0; pointer-events: none; overflow: hidden; }
  .cat-art :global(img) { width: 100%; height: 100%; object-fit: cover; object-position: center; opacity: 0.55; }
  /* darken so the card text stays readable over the image */
  .cat-art::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to top, rgba(11, 27, 53, 0.55), rgba(11, 27, 53, 0.82) 70%); }
</style>
