---
/* Deep, faint thin-line industrial horizon (port cranes, cargo ship, containers,
   factory) — a quiet bottom layer for depth. Refined line-art, not clipart. */
interface Props {
  class?: string;
}
const { class: cls = '' } = Astro.props;
---

<div class:list={['industry', cls]} aria-hidden="true" data-parallax="0.05">
  <span class="industry__glow"></span>
  <svg viewBox="0 0 1440 300" preserveAspectRatio="xMidYMax slice" fill="none" xmlns="http://www.w3.org/2000/svg">
    <g stroke="#aecbef" stroke-opacity="0.92" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <!-- waterline -->
      <line x1="0" y1="250" x2="1440" y2="250" stroke-opacity="0.3" />
      <!-- factory (left) -->
      <path d="M70 250V150h120v100M70 150l30-22 30 22 30-22 30 22" />
      <path d="M150 150v-40h14v40M210 250V120h10M232 250V100h10" />
      <!-- gantry crane 1 -->
      <path d="M360 250V96h150v154M345 96h180M430 96v-26M380 70h100" />
      <path d="M430 96v40M398 136h64" />
      <!-- cargo ship + containers -->
      <path d="M560 250l28 34h470l28-34Z" />
      <path d="M620 250v-46h70v46M694 250v-58h70v58M768 250v-40h70v40M842 250v-52h70v52M916 250v-44h70v44" />
      <path d="M600 204h410" stroke-opacity="0.3" />
      <!-- gantry crane 2 (right) -->
      <path d="M1120 250V70h190v180M1100 70h230M1215 70v-30M1160 40h120" />
      <path d="M1215 70v52M1175 122h80" />
      <!-- distant skyline -->
      <path d="M1340 250v-70h26v70M1374 250v-96h22v96" stroke-opacity="0.35" />
    </g>
  </svg>
</div>

<style>
  /* The thematic layer: a port/industry horizon. Sits ABOVE the floor-grid (z-index 2)
     so the silhouette reads as the skyline; a soft cobalt glow lifts it off the navy. */
  .industry { position: absolute; left: 0; right: 0; bottom: 0; height: min(54%, 430px); pointer-events: none; z-index: 2; opacity: 1; will-change: transform; -webkit-mask-image: linear-gradient(180deg, transparent, #000 32%); mask-image: linear-gradient(180deg, transparent, #000 32%); }
  .industry__glow { position: absolute; left: 0; right: 0; bottom: 0; height: 78%; background: radial-gradient(120% 92% at 50% 100%, rgba(37, 99, 212, 0.26), transparent 72%); }
  .industry svg { position: relative; width: 100%; height: 100%; filter: drop-shadow(0 0 10px rgba(64, 122, 224, 0.35)); }
</style>
