---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
/* "Дальний слой" — wide background photo (2400×1350) for a category detail
   page hero. Drop a file at src/assets/catalog/deep/<key>.(jpg|jpeg|png|webp)
   and it appears, optimised, behind the heading — heavily darkened so the white
   text stays readable. Nothing renders until a file for the key exists. */
interface Props {
  categoryKey: string;
}
const { categoryKey } = Astro.props;
const files = import.meta.glob<{ default: ImageMetadata }>('../../assets/catalog/deep/*.{jpg,jpeg,png,webp}', { eager: true });
const byKey: Record<string, ImageMetadata> = Object.fromEntries(
  Object.entries(files).map(([p, m]) => [p.split('/').pop()!.replace(/\.[a-z]+$/i, ''), m.default]),
);
const img = byKey[categoryKey];
---

{
  img && (
    <div class="cat-deep" aria-hidden="true">
      <Image src={img} alt="" widths={[960, 1440, 2400]} sizes="100vw" format="webp" loading="eager" decoding="async" />
    </div>
  )
}

<style>
  .cat-deep { position: absolute; inset: 0; z-index: 0; pointer-events: none; overflow: hidden; }
  .cat-deep :global(img) { width: 100%; height: 100%; object-fit: cover; object-position: center; opacity: 0.55; }
  /* darken (stronger on the left, where the heading sits) so text stays readable */
  .cat-deep::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to right, rgba(11, 27, 53, 0.9) 0%, rgba(11, 27, 53, 0.66) 55%, rgba(11, 27, 53, 0.5) 100%); }
</style>
