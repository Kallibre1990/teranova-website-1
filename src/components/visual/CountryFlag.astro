---
/* Compact, recognizable SVG flags (code-drawn, no image deps) with a gentle wave.
   Used in the Presence section. */
interface Props {
  code: 'kr' | 'jp' | 'cn' | 'tr';
  title?: string;
  delay?: number;
}
const { code, title = '', delay = 0 } = Astro.props;
const star = 'M0,-1 L0.225,-0.309 0.951,-0.309 0.363,0.118 0.588,0.809 0,0.382 -0.588,0.809 -0.363,0.118 -0.951,-0.309 -0.225,-0.309 Z';
---

<span class="flag" role="img" aria-label={title} style={`animation-delay:${delay}ms`}>
  <span class="flag__inner">
    {code === 'jp' && (
      <svg viewBox="0 0 36 24"><rect width="36" height="24" fill="#fff" /><circle cx="18" cy="12" r="6" fill="#bc002d" /></svg>
    )}
    {code === 'cn' && (
      <svg viewBox="0 0 36 24">
        <rect width="36" height="24" fill="#de2910" />
        <path d={star} fill="#ffde00" transform="translate(7,7) scale(3.4)" />
        <path d={star} fill="#ffde00" transform="translate(13.5,3) scale(1.1)" />
        <path d={star} fill="#ffde00" transform="translate(15.5,6) scale(1.1)" />
        <path d={star} fill="#ffde00" transform="translate(15.5,10) scale(1.1)" />
        <path d={star} fill="#ffde00" transform="translate(13.5,13) scale(1.1)" />
      </svg>
    )}
    {code === 'tr' && (
      <svg viewBox="0 0 36 24">
        <rect width="36" height="24" fill="#e30a17" />
        <circle cx="14" cy="12" r="5" fill="#fff" />
        <circle cx="15.6" cy="12" r="4" fill="#e30a17" />
        <path d={star} fill="#fff" transform="translate(20.5,12) scale(2.4) rotate(20)" />
      </svg>
    )}
    {code === 'kr' && (
      <svg viewBox="0 0 36 24">
        <rect width="36" height="24" fill="#fff" />
        <path d="M13 12a5 5 0 0 1 10 0a2.5 2.5 0 0 0-5 0a2.5 2.5 0 0 1-5 0Z" fill="#c60c30" />
        <path d="M13 12a5 5 0 0 0 10 0a2.5 2.5 0 0 1-5 0a2.5 2.5 0 0 0-5 0Z" fill="#003478" />
        <g stroke="#222" stroke-width="0.8">
          <path d="M5 6.5h3M5 8h3M5 9.5h3" /><path d="M28 6.5h3M28 8h3M28 9.5h3" />
          <path d="M5 14.5h3M5 16h3M5 17.5h3" /><path d="M28 14.5h3M28 16h3M28 17.5h3" />
        </g>
      </svg>
    )}
  </span>
</span>

<style>
  .flag { display: inline-block; width: 40px; height: 27px; perspective: 200px; flex-shrink: 0; }
  .flag__inner {
    display: block; width: 100%; height: 100%; border-radius: 5px; overflow: hidden;
    box-shadow: 0 4px 12px rgba(11, 27, 53, 0.3); transform-origin: left center;
    animation: flag-wave 3.2s ease-in-out infinite;
  }
  .flag__inner svg { display: block; width: 100%; height: 100%; }
  @keyframes flag-wave {
    0%   { transform: rotateY(0deg) skewY(0deg) translateY(0); }
    25%  { transform: rotateY(-22deg) skewY(1.4deg) translateY(-1px); }
    50%  { transform: rotateY(2deg) skewY(0deg) translateY(0); }
    75%  { transform: rotateY(16deg) skewY(-1.4deg) translateY(1px); }
    100% { transform: rotateY(0deg) skewY(0deg) translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) { .flag__inner { animation: none; } }
</style>
